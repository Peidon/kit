{
    "manifest_version": 3,
    "name": "Form Bot Autofill Extension",
    "version": "1.0",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "cookies"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "host_permissions": [
        "http://localhost:8000/*"
    ]
}